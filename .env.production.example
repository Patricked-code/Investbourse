# Investbourse production environment example
# Copy to .env.production and replace every secret before deployment.

NODE_ENV=production

# Public frontend
NEXT_PUBLIC_SITE_URL=https://investbourse.example.com
NEXT_PUBLIC_API_BASE_URL=http://api-gateway:4000
NEXT_PUBLIC_ENABLE_LOCAL_ADMIN_BYPASS=false

# API and CORS
PORT=4000
CORS_ORIGIN=https://investbourse.example.com,https://www.investbourse.example.com
CONTACT_SERVICE_URL=http://contact-service:4010
CONTENT_SERVICE_URL=http://content-service:4020
AUTH_SERVICE_URL=http://auth-service:4030
OFFICE_SERVICE_URL=http://office-service:4040

# Database
POSTGRES_USER=investbourse
POSTGRES_PASSWORD=replace-with-a-very-strong-database-password
POSTGRES_DB=investbourse
DATABASE_URL=postgresql://investbourse:replace-with-a-very-strong-database-password@postgres:5432/investbourse?schema=public

# Security secrets
AUTH_SECRET=replace-with-a-long-random-auth-secret-at-least-32-chars
JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-chars

# First superadmin bootstrap
SEED_ADMIN_EMAIL=admin@investbourse.example.com
SEED_ADMIN_PASSWORD=replace-with-a-very-strong-admin-password
SEED_ADMIN_FULL_NAME=Administrateur Investbourse

# OAuth placeholders for future activation
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
