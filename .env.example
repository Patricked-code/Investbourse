# Investbourse environment example

# Frontend
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_ENABLE_LOCAL_ADMIN_BYPASS=false

# API Gateway
PORT=4000
API_GATEWAY_PORT=4000
CORS_ORIGIN=http://localhost:3000
CONTACT_SERVICE_URL=http://localhost:4010
CONTENT_SERVICE_URL=http://localhost:4020
AUTH_SERVICE_URL=http://localhost:4030
ADMIN_SERVICE_URL=http://localhost:4040
OFFICE_SERVICE_URL=http://localhost:4040

# Services
CONTACT_SERVICE_PORT=4010
CONTENT_SERVICE_PORT=4020
AUTH_SERVICE_PORT=4030
ADMIN_SERVICE_PORT=4040
OFFICE_SERVICE_PORT=4040

# Database
DATABASE_URL=postgresql://investbourse:investbourse_password@localhost:5432/investbourse?schema=public

# Auth providers placeholders
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Security
AUTH_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production
